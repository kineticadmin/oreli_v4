# Oreli — variables d'environnement (voir SPEC-001)
# Copier vers .env et renseigner les valeurs. Aucun secret en dur dans le code.

# Base de données PostgreSQL (Neon)
DATABASE_URL=

# IA produit (Gemini Flash)
GEMINI_API_KEY=

# Stripe (mode test)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mesure (PostHog)
# Clé serveur (non utilisée côté web ; réservée à une mesure côté API).
POSTHOG_KEY=
# Clé publique de projet exposée à la cible web d'Expo (préfixe EXPO_PUBLIC_
# obligatoire). Absente ⇒ la mesure côté application est un no-op silencieux.
EXPO_PUBLIC_POSTHOG_KEY=
# Hôte PostHog (repli sur https://eu.i.posthog.com si absent).
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# URL publique de l'application
APP_URL=http://localhost:8081

# API
PORT=3000

# URL de l'API consommée par l'application (cible web d'Expo)
# En production, pointer vers l'URL publique de l'API (ex. Railway).
EXPO_PUBLIC_API_URL=http://localhost:3000

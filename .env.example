# Oreli — variables d'environnement (voir SPEC-001)
# Copier vers .env et renseigner les valeurs. Aucun secret en dur dans le code.

# Base de données PostgreSQL (Neon)
DATABASE_URL=

# IA produit (Gemini Flash)
GEMINI_API_KEY=

# Stripe (mode test)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mesure
POSTHOG_KEY=

# URL publique de l'application
APP_URL=http://localhost:8081

# API
PORT=3000

# URL de l'API consommée par l'application (cible web d'Expo)
EXPO_PUBLIC_API_URL=http://localhost:3000
